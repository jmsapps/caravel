# Caravel storage configuration example
# Copy to .env and fill values for your target backend.

# -----------------------------------------------------------------------------
# Common Caravel URLs (used by fsspec-backed datasets)
# -----------------------------------------------------------------------------
# Examples:
#   Local: ./examples/fsspec/data/input
#   Azure: abfs://my-container/path/to/input
#   GCP:   gs://my-bucket/path/to/input
#   AWS:   s3://my-bucket/path/to/input
CARAVEL_INPUT_URL=./examples/fsspec/data/input
CARAVEL_OUTPUT_URL=./data/runs

# Optional: explicit backend hint if your config loader uses it.
# Values: local | azure | gcp | aws
CARAVEL_STORAGE_BACKEND=local

# -----------------------------------------------------------------------------
# Azure Blob / ADLS (adlfs)
# Fill only the auth style you use.
# -----------------------------------------------------------------------------
# Account settings
AZURE_STORAGE_ACCOUNT_NAME=

# Auth option A: account key
AZURE_STORAGE_ACCOUNT_KEY=

# Auth option B: SAS token
AZURE_STORAGE_SAS_TOKEN=

# Auth option C: service principal / workload identity
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Optional endpoint override (rare)
# AZURE_STORAGE_BLOB_ENDPOINT=

# -----------------------------------------------------------------------------
# Google Cloud Storage (gcsfs)
# -----------------------------------------------------------------------------
# Path to service-account JSON file
GOOGLE_APPLICATION_CREDENTIALS=

# Optional explicit project
GCP_PROJECT=

# -----------------------------------------------------------------------------
# AWS S3 (s3fs) - optional if you also target S3
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=

# -----------------------------------------------------------------------------
# Runtime / metadata (optional)
# -----------------------------------------------------------------------------
CARAVEL_PIPELINE_NAME=
CARAVEL_RUN_ID=
